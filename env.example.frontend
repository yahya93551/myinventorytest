# Environment Variables - Frontend Only (Safe to commit)
# Copy this file to .env.local and fill in the values

# ============================================
# BACKEND API CONFIGURATION
# ============================================
# Point to your backend API server
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ============================================
# FRONTEND APPLICATION
# ============================================
# The URL where this frontend is deployed
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# MONITORING & ERROR TRACKING (Optional)
# ============================================
# Sentry error tracking (optional)
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# FEATURES & FLAGS (Optional)
# ============================================
# Feature toggles
NEXT_PUBLIC_FEATURES_ENABLED=all

# ============================================
# IMPORTANT SECURITY NOTES
# ============================================
# DO NOT add any of these to this file:
# ❌ Database URLs or credentials
# ❌ API secret keys
# ❌ JWT secrets or signing keys
# ❌ Private API keys (Stripe secret, SendGrid, etc.)
# ❌ Encryption keys
# ❌ Admin credentials
# ❌ Firebase service account
# ❌ Supabase service role key (use anon key from backend)
#
# These variables are PUBLIC and visible to:
# - Frontend code
# - Browser DevTools
# - Page source
# - Anyone who runs npm build
#
# Only use NEXT_PUBLIC_* prefix for non-sensitive data!
